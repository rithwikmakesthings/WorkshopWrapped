#pragma once
// Copy this file to `src/secrets.h` and fill in your WiFi credentials.
// `src/secrets.h` is gitignored so your credentials won't be committed.
//
// The ESP32 only speaks 2.4 GHz WiFi — make sure you use a 2.4 GHz network
// or a hotspot/SSID that broadcasts on that band.

#define WIFI_SSID     "your-2.4ghz-network"
#define WIFI_PASSWORD "your-wifi-password"
